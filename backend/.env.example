# HawkScope Backend — Variables de entorno requeridas
# Copiar este archivo a .env y completar los valores

# Base de datos MySQL (Render o local)
DB_URL=jdbc:mysql://localhost:3306/hawkscope_db
DB_USERNAME=db_admin
DB_PASSWORD=tu_password_aqui
DB_DRIVER=com.mysql.cj.jdbc.Driver
DB_DIALECT=org.hibernate.dialect.MySQLDialect

# JWT — usar una clave de al menos 32 caracteres
JWT_SECRET=cambia-esto-por-una-clave-segura-de-32-chars

# API Key para el interceptor del agente
API_KEY=sk_demo_hawkscope123

# Puerto del servidor 
PORT=8080
